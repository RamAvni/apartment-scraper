{
  "name": "apartment-scraper",
  "type": "module",
  "scripts": {
    "start": "bash ./run.sh",
    "eslint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "orm": "mikro-orm-esm",
    "orm:debug": "NODE_ENV=development pnpm orm debug",
    "build": "tsc",
    "lint": "turbo run eslint ls-lint stylelint",
    "prettier": "prettier --check . --ignore-path ./.prettierignore --ignore-path ./.gitignore --ignore-path ./apps/client/.gitignore --ignore-path ./server/.gitignore",
    "ls-lint": "ls-lint",
    "stylelint": "stylelint **/*.css",
    "spell": "cspell **",
    "knip": "knip",
    "pipeline": "eslint && ls-lint && stylelint && prettier && spell && knip && build"
  },
  "dependencies": {
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/migrations": "catalog:",
    "@mikro-orm/mysql": "catalog:",
    "class-transformer": "catalog:",
    "class-validator": "catalog:",
    "crawlee": "catalog:",
    "dotenv": "catalog:",
    "ollama": "catalog:",
    "playwright": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mikro-orm/cli": "catalog:",
    "@swc/cli": "catalog:",
    "@swc/core": "catalog:",
    "globals": "catalog:",
    "ts-node": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@eslint/js": "catalog:",
    "@ls-lint/ls-lint": "catalog:",
    "@types/node": "catalog:",
    "cspell": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-standard": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
